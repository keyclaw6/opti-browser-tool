{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opti-browser-tool.local/schemas/normalized-task.schema.json",
  "title": "Opti Browser Tool normalized task",
  "x-edge-whitespace-class": "\\u0009-\\u000D\\u001C-\\u0020\\u0085\\u00A0\\u1680\\u2000-\\u200A\\u2028\\u2029\\u202F\\u205F\\u3000\\uFEFF",
  "type": "object",
  "required": [
    "schema_version", "id", "source", "upstream", "goal", "site",
    "interaction_class", "state_change_expected", "suite_membership",
    "difficulty_evidence", "verification", "runtime", "provenance"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 95,
      "pattern": "^[a-z0-9][a-z0-9_-]{0,94}(?![\\s\\S])"
    },
    "source": {"enum": ["real_v1", "webarena_verified", "workarena_l2", "visualwebarena", "warc_bench"]},
    "goal": {"$ref": "#/$defs/nonempty_trimmed"},
    "site": {"$ref": "#/$defs/nonempty_trimmed"},
    "state_change_expected": {"type": "boolean"},
    "suite_membership": {"type": "array", "items": {"type": "string"}, "minItems": 2, "uniqueItems": true},
    "upstream": {
      "type": "object",
      "required": ["benchmark", "version", "native_task_id", "site", "source_manifest", "source_checksum"]
    },
    "difficulty_evidence": {
      "type": "object",
      "required": ["reference_success_percent", "evidence_scope", "per_task_success_percent", "per_task_calibration_status"],
      "properties": {
        "reference_success_percent": {"type": "number", "minimum": 35, "maximum": 70},
        "evidence_scope": {"const": "benchmark_aggregate_not_task_level"},
        "per_task_success_percent": {"type": ["number", "null"]},
        "per_task_calibration_status": {"type": "string"}
      }
    },
    "verification": {"type": "object"},
    "runtime": {"type": "object"},
    "provenance": {"type": "object"},
    "judge_expectations": {
      "type": "object",
      "description": "Optional deterministic cross-check material for the T1 layer (ADR-0016). side_effect_expectation defaults from state_change_expected (true->some, false->none) when absent. state_assertions use the opti-judge assertion mini-language and are authored during bridge bring-up task audits, never by the optimizer.",
      "properties": {
        "side_effect_expectation": {"enum": ["none", "some", "unknown"]},
        "state_assertions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "op"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!\\.)(?![\\s\\S]*\\.\\.)(?![\\s\\S]*\\.(?![\\s\\S]))[^\\u0009-\\u000D\\u001C-\\u0020\\u0085\\u00A0\\u1680\\u2000-\\u200A\\u2028\\u2029\\u202F\\u205F\\u3000\\uFEFF](?:[\\s\\S]*[^\\u0009-\\u000D\\u001C-\\u0020\\u0085\\u00A0\\u1680\\u2000-\\u200A\\u2028\\u2029\\u202F\\u205F\\u3000\\uFEFF])?(?![\\s\\S])"
              },
              "op": {"enum": ["equals", "contains", "exists"]},
              "value": {}
            },
            "additionalProperties": false,
            "allOf": [
              {
                "if": {
                  "required": ["op"],
                  "properties": {"op": {"enum": ["equals", "contains"]}}
                },
                "then": {"required": ["value"]}
              },
              {
                "if": {
                  "required": ["op"],
                  "properties": {"op": {"const": "exists"}}
                },
                "then": {"not": {"required": ["value"]}}
              }
            ]
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "nonempty_trimmed": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\u0009-\\u000D\\u001C-\\u0020\\u0085\\u00A0\\u1680\\u2000-\\u200A\\u2028\\u2029\\u202F\\u205F\\u3000\\uFEFF](?:[\\s\\S]*[^\\u0009-\\u000D\\u001C-\\u0020\\u0085\\u00A0\\u1680\\u2000-\\u200A\\u2028\\u2029\\u202F\\u205F\\u3000\\uFEFF])?(?![\\s\\S])"
    }
  },
  "additionalProperties": true
}
